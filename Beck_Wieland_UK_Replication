################################################################################
# Beck & Wieland (2008) - UK Extension with Correlation Experiment
# R Translation
################################################################################
#
# Replicates B&W (2008) NK model with cross-checking for UK data.
# Tests robustness to correlation between velocity shocks and gap errors.
#
# Author: Kavya Saxena
# Date: March 2026
# Based on: Beck & Wieland (2008, JME) - ccflstrict1p_us.m
#
################################################################################

# Clear workspace
rm(list = ls())
gc()

# Set working directory (adjust as needed)
# setwd("~/your_project_folder")

################################################################################
# MAIN SIMULATION FUNCTION
################################################################################

run_beck_wieland_simulation <- function(ystarbias, 
                                        correlation = 0.0, 
                                        T = NULL,
                                        country_name = "UK",
                                        seed = 965502578) {
  #'
  #' Run Beck & Wieland NK model with cross-checking
  #' 
  #' @param ystarbias Numeric vector of historical output gap bias
  #' @param correlation Correlation between velocity shocks and gap errors
  #' @param T Simulation length (defaults to length of ystarbias)
  #' @param country_name Country name for labels
  #' @param seed Random seed for reproducibility
  #' 
  #' @return List with simulation results
  
  # Set simulation length
  if (is.null(T)) {
    T <- length(ystarbias)
  }
  
  # Ensure ystarbias is correct length
  if (length(ystarbias) < T) {
    ystarbias <- c(ystarbias, rep(0, T - length(ystarbias)))
  } else if (length(ystarbias) > T) {
    ystarbias <- ystarbias[1:T]
  }
  
  # Set random seed
  set.seed(seed)
  
  # ==========================================================================
  # PARAMETERS (Beck & Wieland 2008, Table 1)
  # ==========================================================================
  
  # Phillips curve (from Blanchard/Gali 2005)
  beta <- 0.99
  theta <- 0.5
  lambda_pc <- (1 - beta*theta)*(1 - theta)/theta  # ≈ 0.5025
  
  # IS curve
  phi <- 1.0
  
  # Money demand (Andrés et al. 2006, Ireland 2004)
  gamma_y <- 0.1   # Income elasticity
  gamma_ni <- 0.4  # Interest rate elasticity
  
  # Filter parameter (Gerlach 2004)
  lambda_filter <- 0.2  # Exponential moving average weight
  
  # Targets
  pistar <- 0.0   # Inflation target
  dystar <- 0.0   # Trend output growth
  
  # Shock standard deviations
  sigma_g <- 0.8      # Demand shock
  sigma_gadd <- 0.4   # Demand shock misperception
  sigma_u <- 0.8      # Cost-push shock
  sigma_uadd <- 0.4   # Cost-push misperception
  sigma_e <- 0.8      # Velocity shock
  sigma_eadd <- 0.1   # Velocity misperception
  
  # Cross-checking parameters
  critical <- 1.96  # 5% significance level (two-tailed)
  N_check <- 4      # Number of consecutive periods for trigger
  sigma_mylrstar <- 0.745249684474534  # Calibrated std dev
  
  # ==========================================================================
  # GENERATE CORRELATED SHOCKS
  # ==========================================================================
  
  # Create correlation matrix
  # Shocks: [eps_g, eps_gadd, eps_u, eps_uadd, eps_e, eps_eadd]
  corr_matrix <- diag(6)
  
  # Correlate velocity shock (index 5) with gap perception error (index 2)
  corr_matrix[5, 2] <- correlation
  corr_matrix[2, 5] <- correlation
  
  # Standard deviations
  std_devs <- c(sigma_g, sigma_gadd, sigma_u, sigma_uadd, sigma_e, sigma_eadd)
  
  # Cholesky decomposition for correlation
  L <- chol(corr_matrix)
  
  # Generate correlated shocks
  uncorr_shocks <- matrix(rnorm(T * 6), nrow = T, ncol = 6)
  shocks <- uncorr_shocks %*% t(L) %*% diag(std_devs)
  
  eps_ginnov <- shocks[, 1]
  eps_gadd <- shocks[, 2]
  eps_uinnov <- shocks[, 3]
  eps_uadd <- shocks[, 4]
  eps_einnov <- shocks[, 5]
  eps_eadd <- shocks[, 6]
  
  # Build shock vectors (no persistence: rho=0)
  eps_g <- eps_ginnov
  eps_gperc <- eps_g + eps_gadd
  eps_u <- eps_uinnov
  eps_uperc <- eps_u + eps_uadd
  eps_e <- eps_einnov
  eps_eperc <- eps_e + eps_eadd
  
  # ==========================================================================
  # INITIALIZE VARIABLES
  # ==========================================================================
  
  # WITHOUT cross-checking (suffix _n)
  p_n <- rep(0, T)
  y_n <- rep(0, T)
  ni_n <- rep(pistar, T)
  m_n <- rep(0, T)
  ygap_n <- rep(0, T)
  dp_n <- rep(pistar, T)
  dm_n <- rep(pistar + gamma_y*dystar, T)
  dy_n <- rep(dystar, T)
  dplr_n <- rep(pistar, T)
  dmlr_n <- rep(pistar + gamma_y*dystar, T)
  dylr_n <- rep(dystar, T)
  dmylr_n <- rep(pistar, T)
  
  # WITH cross-checking
  p <- rep(0, T)
  y <- rep(0, T)
  ni <- rep(pistar, T)
  niadd <- rep(0, T)
  m <- rep(0, T)
  ygap <- rep(0, T)
  dp <- rep(pistar, T)
  dm <- rep(pistar + gamma_y*dystar, T)
  dy <- rep(dystar, T)
  dplr <- rep(pistar, T)
  dmlr <- rep(pistar + gamma_y*dystar, T)
  dylr <- rep(dystar, T)
  dmylr <- rep(pistar, T)
  dmlradj <- rep(pistar + gamma_y*dystar, T)
  dylradj <- rep(dystar, T)
  dmylradj <- rep(pistar, T)
  
  # Potential output
  ystar <- rep(0, T)
  ystar_e <- rep(0, T)  # Perceived potential (with bias)
  
  # Test statistic for cross-checking
  test <- rep(0, T)
  
  # Cross-check tracking
  checklast <- 1
  triggers <- list()
  
  # ==========================================================================
  # INITIAL CONDITIONS
  # ==========================================================================
  
  ystar[1] <- 0
  ystar_e[1] <- ystarbias[1]
  
  p[1] <- 0
  ni[1] <- (1/phi) * eps_g[1]
  y[1] <- 0
  m[1] <- p[1] + gamma_y*y[1] - gamma_ni*ni[1]
  
  p_n[1] <- 0
  ni_n[1] <- (1/phi) * eps_g[1]
  y_n[1] <- 0
  m_n[1] <- p_n[1] + gamma_y*y_n[1] - gamma_ni*ni_n[1]
  
  # ==========================================================================
  # MAIN SIMULATION LOOP
  # ==========================================================================
  
  for (t in 2:T) {
    
    # ========================================================================
    # CROSS-CHECK TEST
    # ========================================================================
    
    # Test statistic: standardized filtered adjusted money growth
    test[t] <- (dmylradj[t-1] - pistar) / sigma_mylrstar
    
    # Check for N=4 consecutive periods above critical value
    if (t >= 4) {
      # Positive deviation (money growth too high)
      if (test[t] > critical && test[t-1] > critical && 
          test[t-2] > critical && test[t-3] > critical) {
        niadd[t] <- niadd[checklast] + (dmylr[t-1] - pistar)
        checklast <- t
        dmlradj[t-1] <- pistar + gamma_y*dystar
        dylradj[t-1] <- dystar
        triggers[[length(triggers) + 1]] <- list(direction = "up", time = t)
      }
      # Negative deviation (money growth too low)
      else if (test[t] < -critical && test[t-1] < -critical && 
               test[t-2] < -critical && test[t-3] < -critical) {
        niadd[t] <- niadd[checklast] + (dmylr[t-1] - pistar)
        checklast <- t
        dmlradj[t-1] <- pistar + gamma_y*dystar
        dylradj[t-1] <- dystar
        triggers[[length(triggers) + 1]] <- list(direction = "down", time = t)
      }
    }
    
    # Maintain last adjustment if no new trigger
    if (t > 1 && niadd[t] == 0) {
      niadd[t] <- niadd[checklast]
    }
    
    # ========================================================================
    # POTENTIAL OUTPUT & PERCEPTIONS
    # ========================================================================
    
    # True potential (deterministic trend)
    ystar[t] <- dystar + ystar[t-1]
    
    # Perceived potential (true + historical bias)
    ystar_e[t] <- ystar[t] + ystarbias[t]
    
    # ========================================================================
    # EXPECTATIONS (Under discretion)
    # ========================================================================
    
    # Rational expectations under discretion with strict targeting
    pi_t1 <- pistar  # E_t[π_{t+1}] = target
    y_t1 <- 0        # E_t[y_{t+1}] = potential (normalized to 0)
    
    # ========================================================================
    # INTEREST RATE (Optimal NK policy)
    # ========================================================================
    
    # WITHOUT cross-checking
    ni_n[t] <- (-1/phi)*ystar_e[t] + 
               (1/(phi*lambda_pc))*eps_uperc[t] + 
               (1/phi)*eps_gperc[t]
    
    # WITH cross-checking (adds adjustment term)
    ni[t] <- (-1/phi)*ystar_e[t] + 
             (1/(phi*lambda_pc))*eps_uperc[t] + 
             (1/phi)*eps_gperc[t] + 
             (1/(phi*lambda_pc))*niadd[t]
    
    # ========================================================================
    # OUTPUT (IS curve)
    # ========================================================================
    
    y[t] <- y_t1 - phi*(ni[t] - pi_t1) + eps_g[t]
    ygap[t] <- y[t] - ystar[t]
    
    y_n[t] <- y_t1 - phi*(ni_n[t] - pi_t1) + eps_g[t]
    ygap_n[t] <- y_n[t] - ystar[t]
    
    # ========================================================================
    # INFLATION (Phillips curve)
    # ========================================================================
    
    dp[t] <- lambda_pc*ygap[t] + beta*pi_t1 + eps_u[t]
    dp_n[t] <- lambda_pc*ygap_n[t] + beta*pi_t1 + eps_u[t]
    
    # ========================================================================
    # PRICE LEVEL & MONEY DEMAND
    # ========================================================================
    
    # Price level (cumulative inflation)
    p[t] <- p[t-1] + dp[t]
    p_n[t] <- p_n[t-1] + dp_n[t]
    
    # Money demand: m - p = γ_y*y - γ_i*i + v
    m[t] <- p[t] + gamma_y*y[t] - gamma_ni*ni[t] + eps_e[t]
    m_n[t] <- p_n[t] + gamma_y*y_n[t] - gamma_ni*ni_n[t] + eps_e[t]
    
    # Growth rates
    dm[t] <- m[t] - m[t-1]
    dy[t] <- y[t] - y[t-1]
    dm_n[t] <- m_n[t] - m_n[t-1]
    dy_n[t] <- y_n[t] - y_n[t-1]
    
    # ========================================================================
    # FILTERED VARIABLES (Exponential moving average)
    # ========================================================================
    
    # WITH cross-checking
    dplr[t] <- dplr[t-1] + lambda_filter*(dp[t] - dplr[t-1])
    dmlr[t] <- dmlr[t-1] + lambda_filter*(dm[t] - dmlr[t-1])
    dylr[t] <- dylr[t-1] + lambda_filter*(dy[t] - dylr[t-1])
    dmylr[t] <- dmlr[t] - gamma_y*dylr[t]  # Adjusted for output growth
    
    # Adjusted filter (resets after cross-check trigger)
    dmlradj[t] <- dmlradj[t-1] + lambda_filter*(dm[t] - dmlradj[t-1])
    dylradj[t] <- dylradj[t-1] + lambda_filter*(dy[t] - dylradj[t-1])
    dmylradj[t] <- dmlradj[t] - gamma_y*dylradj[t]
    
    # WITHOUT cross-checking
    dplr_n[t] <- dplr_n[t-1] + lambda_filter*(dp_n[t] - dplr_n[t-1])
    dmlr_n[t] <- dmlr_n[t-1] + lambda_filter*(dm_n[t] - dmlr_n[t-1])
    dylr_n[t] <- dylr_n[t-1] + lambda_filter*(dy_n[t] - dylr_n[t-1])
    dmylr_n[t] <- dmlr_n[t] - gamma_y*dylr_n[t]
  }
  
  # ==========================================================================
  # COMPUTE STATISTICS
  # ==========================================================================
  
  # Find active bias period
  bias_active <- abs(ystarbias) > 0.1
  if (any(bias_active)) {
    t_start <- which(bias_active)[1]
    t_end <- tail(which(bias_active), 1)
  } else {
    t_start <- 1
    t_end <- T
  }
  
  # Number of triggers
  n_triggers <- length(triggers)
  
  # Variance calculations
  var_pi_no_cc <- var(dp_n)
  var_pi_with_cc <- var(dp)
  improvement_pct <- ifelse(var_pi_no_cc > 0, 
                            100*(var_pi_no_cc - var_pi_with_cc)/var_pi_no_cc, 
                            0)
  
  # Correlations
  corr_money_inflation_no_cc <- cor(dmylr_n, dplr_n)
  corr_money_inflation_with_cc <- cor(dmylr, dplr)
  empirical_corr_velocity_gap_error <- cor(eps_e, eps_gadd)
  
  # Return results
  return(list(
    correlation = correlation,
    country = country_name,
    var_pi_no_cc = var_pi_no_cc,
    var_pi_with_cc = var_pi_with_cc,
    improvement_pct = improvement_pct,
    n_triggers = n_triggers,
    triggers = triggers,
    peak_bias = max(abs(ystarbias)),
    corr_money_inflation_no_cc = corr_money_inflation_no_cc,
    corr_money_inflation_with_cc = corr_money_inflation_with_cc,
    empirical_corr_velocity_gap_error = empirical_corr_velocity_gap_error,
    # Store time series for plotting
    dp = dp,
    dp_n = dp_n,
    dmylr = dmylr,
    dmylr_n = dmylr_n,
    niadd = niadd,
    test = test,
    ystarbias = ystarbias,
    t_start = t_start,
    t_end = t_end,
    T = T
  ))
}

################################################################################
# PLOTTING FUNCTIONS
################################################################################

plot_results <- function(results_list, correlations, output_dir = "results") {
  #'
  #' Generate publication-quality figures
  #' 
  #' @param results_list List of simulation results
  #' @param correlations Vector of correlation values tested
  #' @param output_dir Directory to save figures
  
  # Create output directory
  if (!dir.exists(output_dir)) {
    dir.create(output_dir, recursive = TRUE)
  }
  
  # ========================================================================
  # Figure 1: Performance across correlations (3x3 grid)
  # ========================================================================
  
  png(file.path(output_dir, "correlation_experiment.png"), 
      width = 18, height = 12, units = "in", res = 150)
  
  par(mfrow = c(3, 3), mar = c(4, 4, 3, 1), oma = c(0, 0, 3, 0))
  
  critical <- 1.96
  sigma_mylrstar <- 0.745
  
  for (i in 1:length(correlations)) {
    rho <- correlations[i]
    res <- results_list[[i]]
    
    time <- 1:res$T
    
    # Row 1: Inflation comparison
    plot(time, res$dp_n, type = "l", col = "blue", lwd = 1, 
         ylim = range(c(res$dp_n, res$dp)),
         xlab = "", ylab = "Percent",
         main = sprintf("ρ = %+.1f: Inflation\nImprovement: %.1f%%", 
                       rho, res$improvement_pct))
    lines(time, res$dp, col = "red", lwd = 2)
    abline(h = 0, lty = 2, col = "black", lwd = 0.5)
    rect(res$t_start, par("usr")[3], res$t_end, par("usr")[4], 
         col = rgb(0.5, 0.5, 0.5, 0.1), border = NA)
    legend("topright", legend = c("No CC", "With CC"), 
           col = c("blue", "red"), lwd = c(1, 2), cex = 0.8)
    grid(col = "gray", lty = 3)
    
    # Row 2: Filtered money growth
    plot(time, res$dmylr_n, type = "l", col = "darkgreen", lwd = 1,
         ylim = range(c(res$dmylr_n, res$dmylr)),
         xlab = "", ylab = "Percent",
         main = sprintf("Filtered Money Growth\nTriggers: %d", res$n_triggers))
    lines(time, res$dmylr, col = "darkgreen", lwd = 2)
    abline(h = 0, lty = 2, col = "black", lwd = 0.5)
    abline(h = c(critical*sigma_mylrstar, -critical*sigma_mylrstar), 
           lty = 3, col = "red", lwd = 0.5)
    rect(res$t_start, par("usr")[3], res$t_end, par("usr")[4], 
         col = rgb(0.5, 0.5, 0.5, 0.1), border = NA)
    # Mark triggers
    if (res$n_triggers > 0) {
      for (trig in res$triggers) {
        abline(v = trig$time, lty = 3, col = "orange", lwd = 1.5)
      }
    }
    legend("topright", legend = c("No CC", "With CC"), 
           col = c("darkgreen", "darkgreen"), lwd = c(1, 2), cex = 0.8)
    grid(col = "gray", lty = 3)
    
    # Row 3: Cross-check adjustment
    plot(time, res$niadd, type = "l", col = "purple", lwd = 2,
         xlab = "Period", ylab = "Percentage points",
         main = "Interest Rate Adjustment")
    abline(h = 0, lty = 2, col = "black", lwd = 0.5)
    # Mark triggers
    if (res$n_triggers > 0) {
      for (trig in res$triggers) {
        abline(v = trig$time, lty = 3, col = "orange", lwd = 1.5)
      }
    }
    grid(col = "gray", lty = 3)
  }
  
  mtext(sprintf("Beck & Wieland (2008): Cross-Checking Performance - %s", 
                results_list[[1]]$country), 
        outer = TRUE, cex = 1.5, font = 2)
  
  dev.off()
  cat(sprintf("Saved: %s/correlation_experiment.png\n", output_dir))
  
  # ========================================================================
  # Figure 2: Summary comparison bars
  # ========================================================================
  
  png(file.path(output_dir, "comparison_bars.png"), 
      width = 12, height = 5, units = "in", res = 150)
  
  par(mfrow = c(1, 2), mar = c(4, 4, 3, 1))
  
  # Extract data
  var_no_cc <- sapply(results_list, function(r) r$var_pi_no_cc)
  var_with_cc <- sapply(results_list, function(r) r$var_pi_with_cc)
  improvements <- sapply(results_list, function(r) r$improvement_pct)
  
  # Variance comparison
  x <- 1:length(correlations)
  width <- 0.35
  
  barplot_data <- rbind(var_no_cc, var_with_cc)
  bp <- barplot(barplot_data, beside = TRUE, 
                names.arg = sprintf("ρ=%+.1f", correlations),
                col = c("lightcoral", "lightgreen"),
                ylab = "var(π)",
                main = sprintf("Inflation Variance - %s", results_list[[1]]$country),
                ylim = c(0, max(var_no_cc)*1.1))
  legend("topright", legend = c("No Cross-Check", "With Cross-Check"),
         fill = c("lightcoral", "lightgreen"))
  grid(ny = NULL, nx = NA, col = "gray", lty = 3)
  
  # Improvement percentage
  avg_improvement <- mean(improvements)
  bp2 <- barplot(improvements, 
                 names.arg = sprintf("ρ=%+.1f", correlations),
                 col = c("skyblue", "steelblue", "navy"),
                 ylab = "Improvement (%)",
                 main = "Performance Improvement from Cross-Checking",
                 ylim = c(0, max(improvements)*1.1))
  abline(h = avg_improvement, col = "red", lty = 2, lwd = 2)
  text(mean(bp2), avg_improvement, 
       sprintf("Average: %.1f%%", avg_improvement),
       pos = 3, col = "red", font = 2)
  grid(ny = NULL, nx = NA, col = "gray", lty = 3)
  
  dev.off()
  cat(sprintf("Saved: %s/comparison_bars.png\n", output_dir))
}

